<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="300dp"
    android:height="200dp"
    android:viewportWidth="300"
    android:viewportHeight="200">
    <!-- Studio background wall in charcoal gray -->
    <path
        android:pathData="M 0,0 L 300,0 L 300,200 L 0,200 Z"
        android:fillColor="#1E293B"/>
    
    <!-- LED Glow ring light on the left -->
    <path
        android:pathData="M 40,80 A 30,30 0 1 0 40,140 A 30,30 0 1 0 40,80"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="8"
        android:fillColor="#334155"/>
    <path
        android:pathData="M 40,75 L 40,195"
        android:strokeColor="#475569"
        android:strokeWidth="4"/>

    <!-- Shure mic in front profile -->
    <path
        android:pathData="M 200,100 L 220,130"
        android:strokeColor="#0284C7"
        android:strokeWidth="10"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M 180,80 L 210,110"
        android:strokeColor="#0F172A"
        android:strokeWidth="15"
        android:strokeLineCap="round"/>
        
    <!-- Workspace desk level -->
    <path
        android:pathData="M 0,165 L 300,165 L 300,200 L 0,200 Z"
        android:fillColor="#451A03"/>

    <!-- Open laptop representation on the right -->
    <path
        android:pathData="M 210,130 L 270,130 L 285,165 L 210,165 Z"
        android:fillColor="#64748B"/>
    <path
        android:pathData="M 215,135 H 265 V 160 H 215 Z"
        android:fillColor="#0D9488"/>

    <!-- Portrait silhouette center-left of the founder -->
    <path
        android:pathData="M 100,165 C 100,120 120,110 140,110 C 160,110 180,120 180,165 Z"
        android:fillColor="#3B82F6"/>
    <path
        android:pathData="M 140,55 A 20,20 0 1 0 140,95 A 20,20 0 1 0 140,55"
        android:fillColor="#F3F4F6"/>
</vector>
